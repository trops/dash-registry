{
    "name": "dash-registry",
    "version": "1.1.23",
    "private": true,
    "description": "Package registry and marketplace for Dash",
    "scripts": {
        "dev": "npm run build-index && next dev --port 3001",
        "build": "npm run build-index && next build",
        "start": "next start",
        "build-index": "node scripts/build-index.js",
        "lint": "next lint",
        "validate": "node scripts/validate-packages.js",
        "check": "npm run validate && npm run lint && npm run build",
        "preversion": "npm run check",
        "create-project": "node scripts/create-project.js",
        "migrate": "node scripts/migrate-to-dynamo.js",
        "migrate:dry": "node scripts/migrate-to-dynamo.js --dry-run"
    },
    "dependencies": {
        "@aws-amplify/backend": "^1.21.0",
        "@aws-amplify/backend-cli": "^1.8.2",
        "@aws-amplify/ui-react": "^6.15.1",
        "@aws-sdk/client-cognito-identity-provider": "^3.1004.0",
        "@aws-sdk/client-dynamodb": "^3.1004.0",
        "@aws-sdk/client-s3": "^3.1004.0",
        "@aws-sdk/lib-dynamodb": "^3.1004.0",
        "@aws-sdk/s3-request-presigner": "^3.1004.0",
        "aws-amplify": "^6.16.2",
        "aws-jwt-verify": "^4.0.1",
        "fuse.js": "^7.0.0",
        "next": "^14.2.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "autoprefixer": "^10.4.0",
        "aws-cdk-lib": "^2.241.0",
        "constructs": "^10.5.1",
        "eslint": "^8.57.1",
        "eslint-config-next": "^14.2.35",
        "postcss": "^8.4.0",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.4.0"
    }
}
